#!/usr/bin/env php
<?php

use Indoctrinate\Command\DatabaseAnalyzerCommand;
use Indoctrinate\Command\GenerateDocsCommand;
use Indoctrinate\Command\GenerateEntitiesCommand;
use Indoctrinate\Service\EntityBuilderService;
use Indoctrinate\Service\SchemaDiscoveryService;
use Symfony\Component\Console\Application;

$autoloadPaths = [
        __DIR__ . '/../vendor/autoload.php',
        __DIR__ . '/../../../autoload.php',
];

foreach ($autoloadPaths as $path) {
    if (!file_exists($path)) {
        continue;
    }

    require $path;
    break;
}

if (!class_exists(DatabaseAnalyzerCommand::class)) {
    fwrite(STDERR, "Autoload failed. Did you run `composer install`?\n");
    exit(1);
}

$application = new Application();
$application->add(new DatabaseAnalyzerCommand());
$application->add(new GenerateDocsCommand());
$application->add(new GenerateEntitiesCommand(new SchemaDiscoveryService(), new EntityBuilderService()));
$application->run();
