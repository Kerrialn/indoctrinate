{
  "name": "kerrialn/indoctrinate",
  "license": "MIT",
  "description": "An automated package helps you align your database with Doctrine or simply fix database issues.",
  "bin": ["bin/indoctrinate"],
  "autoload": {
    "psr-4": { "Indoctrinate\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "IndoctrinateTest\\": "tests/" }
  },
  "require": {
    "php": ">=8.1",
    "symfony/console": "^5.4 || ^6.4 || ^7.2",
    "symfony/finder": "^5.4 || ^6.4 || ^7.2",
    "symfony/filesystem": "^5.4 || ^6.4 || ^7.2",
    "nikic/php-parser": "^5.4",
    "nette/utils": "^4.0",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "rector/rector": "^2.1",
    "symplify/easy-coding-standard": "^12.5"
  },
  "scripts": {
    "rector": "vendor/bin/rector p --ansi",
    "rector-dry": "vendor/bin/rector p --dry-run --ansi",
    "phpstan": "php -d memory_limit=256M vendor/bin/phpstan analyze",
    "check-cs": "vendor/bin/ecs check --ansi",
    "fix-cs": "vendor/bin/ecs check --fix --ansi",
    "test": "vendor/bin/phpunit tests"
  },
  "authors": [
    { "name": "Kerrial Newham", "email": "kerrialbeckettnewham@gmail.com" }
  ]
}